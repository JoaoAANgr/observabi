        dados_invalido2 = DadosAnalise(
            labels=['Serviço A', 'Serviço B'],
            values=[100]  # ❌ Tamanho diferente!
        )
    except ValueError as e:
        print(f"✅ Validação de tamanho funcionou! Erro: {e}")


def exemplo_2_analise_vetorizada():
    """Exemplo 2: Análise com operações vetorizadas (NumPy)."""
    print("\n" + "="*60)
    print("EXEMPLO 2: Análise Vetorizada com NumPy")
    print("="*60)
    
    from models import DadosAnalise, ConfiguracaoGrafico
    from analise_avancada_v2 import AnaliseDados
    import time
    
    dados = DadosAnalise(
        labels=['Duplicidade de usuário', 'Conexão BD', 'Timeout', 'Memória', 'Rede'],
        values=[124, 51, 41, 36, 32]
    )
    
    config = ConfiguracaoGrafico(dpi=150)  # Menor DPI para teste
    analise = AnaliseDados(dados, config)
    
    # Gerar gráficos
    start = time.time()
    
    print("\n🎨 Gerando gráficos...")
    figuras = {
        'barras_vertical': analise.grafico_barras_vertical(),
        'pizza': analise.grafico_pizza(),
        'pareto': analise.grafico_pareto(),
    }
    
    tempo_viz = time.time() - start
    
    for nome, fig in figuras.items():
        analise.salvar_figura(fig, f'exemplos/{nome}.png')
    
    print(f"✅ {len(figuras)} gráficos gerados em {tempo_viz:.2f}s")
    
    # Relatório estatístico
    print("\n📊 Estatísticas:")
    stats = analise.gerar_relatorio_estatistico()
    for chave, valor in stats.items():
        print(f"   {chave}: {valor:.2f}" if isinstance(valor, float) else f"   {chave}: {valor}")


def exemplo_3_ocr_easyocr():
