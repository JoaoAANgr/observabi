def exemplo_1_validacao_dados():
    """Exemplo 1: Validação automática com Pydantic."""
    print("\n" + "="*60)
    print("EXEMPLO 1: Validação Automática com Pydantic")
    print("="*60)
    
    from models import DadosAnalise
    
    # ✅ Válido
    try:
        dados = DadosAnalise(
            labels=['Serviço A', 'Serviço B', 'Serviço C'],
            values=[100, 50, 75]
        )
        print("✅ Dados válidos aceitos")
        print(f"   Total: {sum(dados.values)}")
    except ValueError as e:
