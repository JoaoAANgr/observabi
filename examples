def exemplo_7_decoradores_performance():
    """Exemplo 7: Decoradores para performance e validação."""
    print("\n" + "="*60)
    print("EXEMPLO 7: Decoradores para Performance")
    print("="*60)
    
    from utils import medir_tempo, cache_resultado, validar_nao_vazio
    import time
    
    @medir_tempo
    def operacao_lenta():
        """Operação que será cronometrada."""
        time.sleep(0.1)
        return "Resultado"
    
    resultado = operacao_lenta()
    print(f"✅ Resultado: {resultado}")
    
    @cache_resultado(ttl_segundos=60)
    def carregar_dados_pesado():
        """Dados são cacheados por 60 segundos."""
        time.sleep(0.1)
        return {'dados': [1, 2, 3]}
    
    print("\n⏱️  Primeira chamada (sem cache):")
    start = time.time()
    r1 = carregar_dados_pesado()
    print(f"   Tempo: {time.time() - start:.3f}s")
    
    print("\n⚡ Segunda chamada (com cache):")
    start = time.time()
    r2 = carregar_dados_pesado()
    print(f"   Tempo: {time.time() - start:.6f}s (cache!)")
    
    @validar_nao_vazio('labels')
    def processar(labels):
        return f"Processando {len(labels)} labels"
    
    print(f"\n✅ Validação: {processar(['A', 'B', 'C'])}")


def exemplo_8_type_hints_e_mypy():
    """Exemplo 8: Type hints para segurança."""
    print("\n" + "="*60)
    print("EXEMPLO 8: Type Hints e Type Safety")
    print("="*60)
    
    from typing import List
    from models import DadosAnalise
    from analise_avancada_v2 import AnaliseDados
    from matplotlib.figure import Figure
    
    def processar_analise(
        labels: List[str],
        values: List[float],
        titulo: str = "Análise Padrão"
    ) -> Figure:
        """
        Função com type hints completos.
        
        Args:
            labels: Lista de labels
            values: Lista de valores
            titulo: Título da análise
        
        Returns:
            Figure do Matplotlib
        """
        dados = DadosAnalise(labels=labels, values=values)
        analise = AnaliseDados(dados)
        return analise.grafico_barras_vertical()
    
    print("✅ Função com type hints:")
    print(f"   Assinatura: {processar_analise.__annotations__}")
    
    # IDE consegue:
    # 1. Autocompletar parâmetros
    # 2. Detectar erros de tipo em tempo de escrita
    # 3. Documentação automática
    
    print("\n💡 Benefícios:")
    print("   ✅ IDE pode autocompletar")
    print("   ✅ Mypy detecta erros antes da execução")
    print("   ✅ Código auto-documentado")
    print("   ✅ Refactoring seguro")


